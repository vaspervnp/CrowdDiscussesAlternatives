<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    Machine-level feeds are cleared on purpose: this repository restores from nuget.org
    and nothing else. Without this, a developer's private feed takes part in resolution,
    which makes builds depend on who is running them and produces confusing 403s for
    public packages.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

</configuration>
