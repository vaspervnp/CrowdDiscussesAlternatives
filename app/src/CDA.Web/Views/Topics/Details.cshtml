@model CDA.Application.Topics.TopicView
@using CDA.Domain.Topics
@{
    ViewData["Title"] = Model.Subject;
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<h1>@Model.Subject</h1>

<p class="text-muted">
    @Model.Phase
    @if (Model.Visibility == TopicVisibility.InviteOnly)
    {
        <span class="badge bg-secondary">invite only</span>
    }
    @if (Model.IsClosed)
    {
        <span class="badge bg-dark">closed</span>
    }
    @if (Model.ClosesAtUtc is { } closes)
    {
        <span>&middot; to conclude by @closes.ToString("d MMMM yyyy")</span>
    }
</p>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <p class="col-lg-9" style="white-space: pre-wrap">@Model.Description</p>
}

<div class="card col-lg-6 my-4">
    <div class="card-body">
        <h2 class="h6 card-title">How important is this topic?</h2>

        @if (Model.ScoreSum is { } score)
        {
            <p class="mb-2">
                <span class="h4">@(score > 0 ? "+" : "")@score</span>
                <small class="text-muted">from @Model.VoteCount vote@(Model.VoteCount == 1 ? "" : "s")</small>
            </p>
        }
        else
        {
            <p class="text-muted mb-2">
                Tallies are hidden until this topic closes, so that seeing the running total
                does not shape how people vote. Ranking still applies.
            </p>
        }

        @if (Model.CanVote)
        {
            <form method="post" asp-action="Vote" asp-route-id="@Model.Id" class="d-inline">
                @* -1 / 0 / +1 are the only valid votes; 0 is a recorded abstention. *@
                <button name="value" value="1" class="btn btn-sm @(Model.MyVote == 1 ? "btn-success" : "btn-outline-success")">
                    Important
                </button>
                <button name="value" value="0" class="btn btn-sm @(Model.MyVote == 0 ? "btn-secondary" : "btn-outline-secondary")">
                    Neutral
                </button>
                <button name="value" value="-1" class="btn btn-sm @(Model.MyVote == -1 ? "btn-danger" : "btn-outline-danger")">
                    Not important
                </button>
            </form>

            @if (Model.MyVote is not null)
            {
                <form method="post" asp-action="WithdrawVote" asp-route-id="@Model.Id" class="d-inline">
                    <button class="btn btn-sm btn-link text-muted">Withdraw my vote</button>
                </form>
            }
        }
        else if (Model.IsClosed)
        {
            <p class="text-muted mb-0">This topic has closed.</p>
        }
        else if (User.Identity?.IsAuthenticated != true)
        {
            <p class="mb-0"><a asp-controller="Account" asp-action="Login">Sign in</a> to vote.</p>
        }
    </div>
</div>

@if (Model.CanJoin)
{
    <form method="post" asp-action="Join" asp-route-id="@Model.Id" class="mb-3">
        <button class="btn btn-outline-primary">Join this topic</button>
        <span class="form-text ms-2">Members can add proposals and take part in the discussion.</span>
    </form>
}

@if (Model.CanAdminister && !Model.IsClosed)
{
    <div class="border-top pt-3">
        <h2 class="h6">Facilitator</h2>
        <form method="post" asp-action="ChangePhase" asp-route-id="@Model.Id" class="d-inline">
            @if (Model.Phase == TopicPhase.Discussing)
            {
                <button name="phase" value="@TopicPhase.Proposing" class="btn btn-sm btn-outline-primary">
                    Open for proposals
                </button>
            }
            <button name="phase" value="@TopicPhase.Closed" class="btn btn-sm btn-outline-dark">
                Close the topic
            </button>
        </form>
        <div class="form-text">Phases only move forward; a closed topic cannot be reopened.</div>
    </div>
}
