@model CDA.Web.Models.EvaluateViewModel
@using CDA.Domain.Evaluation
@{
    ViewData["Title"] = L["Evaluate an alternative"];
    var evaluation = Model.Evaluation;
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-controller="Groups" asp-action="Details" asp-route-topicId="@Model.TopicId"
       asp-route-id="@evaluation.GroupId" class="text-decoration-none">
        &larr; @evaluation.GroupDescription
    </a>
</p>
<h1 class="h3">@L["Evaluate this alternative"]</h1>

<p class="text-muted col-lg-9">
    @Html.Raw(L.Format("Score how well this combination satisfies each requirement the topic agreed on, weighted by how much each requirement matters to you. This is a tool for thinking before you vote — %emphasis%.",
        ("emphasis", $"<strong>{L["nobody else can see it"]}</strong>")))
</p>

<form method="post" class="col-lg-10">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@L["Requirement"]</th>
                <th style="width: 11rem">
                    @L["How much it matters"]<br />
                    <small class="text-muted fw-normal">@L["to you, across this topic"]</small>
                </th>
                <th style="width: 11rem">
                    @L["How well this meets it"]<br />
                    <small class="text-muted fw-normal">@L["this alternative only"]</small>
                </th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in evaluation.Rows)
        {
            <tr>
                <td>
                    @row.Text
                    <input type="hidden" name="requirementIds" value="@row.RequirementId" />
                </td>
                <td>
                    <select name="weights" class="form-select form-select-sm">
                        @for (var w = RequirementWeight.Minimum; w <= RequirementWeight.Maximum; w++)
                        {
                            <option value="@w" selected="@(w == row.Weight)">
                                @(w == 0 ? L["0 — not at all"] : w == 5 ? L["5 — decisive"] : (object)w)
                            </option>
                        }
                    </select>
                </td>
                <td>
                    <select name="scores" class="form-select form-select-sm">
                        @for (var s = RequirementScore.Minimum; s <= RequirementScore.Maximum; s++)
                        {
                            <option value="@s" selected="@(s == row.Score)">
                                @(s == 0 ? L["0 — not at all"] : s == 5 ? L["5 — fully"] : (object)s)
                            </option>
                        }
                    </select>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @* Weights are shared across the topic on purpose — see the manual. Saying so here is not
       optional: otherwise changing one would silently rewrite every other evaluation. *@
    <div class="alert alert-light border">
        <strong>@L["Weights carry across this topic."]</strong>
        @L["Changing how much a requirement matters to you also changes it in every other alternative you evaluate here. That is what lets the totals be compared with each other — if each alternative had its own weights, the scores would be on different scales and comparing them would mean nothing."]
    </div>

    @if (evaluation.HasBeenEvaluated)
    {
        <p class="text-muted">
            @L.Format("You last evaluated this on %date% UTC — scoring %score%. Re-evaluating replaces that.",
                ("date", evaluation.UpdatedAtUtc!.Value.ToString("d MMM yyyy HH:mm")),
                ("score", evaluation.Percentage is { } percent ? $"{evaluation.Total} ({percent}%)" : evaluation.Total.ToString()))
        </p>
    }

    <button type="submit" class="btn btn-primary">@L["Save my evaluation"]</button>
    <a asp-action="Compare" asp-route-topicId="@Model.TopicId" class="btn btn-link">
        @L["Compare all alternatives"]
    </a>
</form>
