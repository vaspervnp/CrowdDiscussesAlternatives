@model CDA.Web.Models.ParameterListViewModel
@using CDA.Domain.Parameters
@{
    ViewData["Title"] = L["Make a factor table"];
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="text-decoration-none">
        &larr; @L["Factor tables"]
    </a>
</p>
<h1 class="h3">@L["Make a factor table"]</h1>

<form method="post" class="col-lg-8">
    <div class="mb-3">
        <label class="form-label" for="name">@L["What is this table about?"]</label>
        <input name="name" id="name" class="form-control" required
               maxlength="@ParameterTable.NameMaxLength"
               placeholder="@L["e.g. How the traffic factors pull against each other"]" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="factors">@L["The key factors, one per line"]</label>
        <textarea name="factors" id="factors" class="form-control" rows="8" required
                  placeholder="@L["e.g. Journey time, Air quality, Cost to residents, Shop takings — one per line"]"></textarea>
        <div class="form-text">
            @L.Format("Between 2 and %max% factors. The grid is square, so twelve factors already means well over a hundred judgements and a table nobody can read across — deciding which are genuinely key is part of the exercise.", ("max", ParameterTable.MaxParameters))
        </div>
    </div>

    <button type="submit" class="btn btn-primary">@L["Create the table"]</button>
    <a asp-action="Index" asp-route-topicId="@Model.TopicId" class="btn btn-link">@L["Cancel"]</a>
    <div class="form-text">
        @L["It starts private to you. You can share it with the topic whenever you like."]
    </div>
</form>
