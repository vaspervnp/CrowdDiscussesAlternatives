@model CDA.Web.Models.ParameterListViewModel
@{
    ViewData["Title"] = $"Factor tables — {Model.TopicSubject}";
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-controller="Topics" asp-action="Details" asp-route-id="@Model.TopicId"
       class="text-decoration-none">&larr; @Model.TopicSubject</a>
</p>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Factor tables</h1>
    @if (Model.CanCreate)
    {
        <a asp-action="Create" asp-route-topicId="@Model.TopicId" class="btn btn-primary">Make a table</a>
    }
</div>

<p class="text-muted col-lg-9">
    A grid of how the key factors in this problem push on each other. Solutions usually fail not
    because a measure does not work, but because it works while damaging something else that
    mattered — this is a place to write that down and see it.
</p>

<p class="text-muted col-lg-9">
    Each person builds their own. A shared table is one participant's reading of the problem,
    offered to the topic, not an agreed fact — so tables are never merged and always carry their
    author's name.
</p>

@if (Model.Tables.Count == 0)
{
    <p class="text-muted fst-italic">Nothing here yet.</p>
}

<div class="list-group col-lg-9">
@foreach (var table in Model.Tables)
{
    <a asp-action="Details" asp-route-topicId="@Model.TopicId" asp-route-id="@table.Id"
       class="list-group-item list-group-item-action">
        @table.Name
        <small class="d-block text-muted">
            @table.OwnerDisplayName &middot; @table.ParameterCount factors
            @if (table.IsMine && !table.IsShared)
            {
                <span class="badge bg-secondary">private to you</span>
            }
            else if (table.IsShared)
            {
                <span class="badge bg-info text-dark">shared</span>
            }
        </small>
    </a>
}
</div>
