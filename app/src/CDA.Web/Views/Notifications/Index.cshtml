@model CDA.Web.Models.NotificationsViewModel
@using CDA.Domain.Notifications
@{
    ViewData["Title"] = L["Notifications"];
}

<h1>@L["Notifications"]</h1>

<div class="col-lg-9">
    <form method="post" asp-action="SetDelivery" class="row g-2 align-items-end mb-3">
        <div class="col-auto">
            <label class="form-label mb-0" for="delivery">@L["Email me"]</label>
            <select name="delivery" id="delivery" class="form-select">
                <option value="@NotificationDelivery.Daily" selected="@(Model.Delivery == NotificationDelivery.Daily)">
                    @L["once a day, gathered together"]
                </option>
                <option value="@NotificationDelivery.Immediate" selected="@(Model.Delivery == NotificationDelivery.Immediate)">
                    @L["as things happen"]
                </option>
                <option value="@NotificationDelivery.None" selected="@(Model.Delivery == NotificationDelivery.None)">
                    @L["never — I will look here"]
                </option>
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary">@L["Save"]</button>
        </div>
    </form>

    @if (!Model.EmailWorks)
    {
        @* Said plainly rather than offering a setting that quietly does nothing. *@
        <div class="alert alert-info">
            <strong>@L["Email is not switched on for this installation."]</strong>
            @L["Nothing is being sent, whatever you choose above — but everything is still listed here, and your preference is remembered for when it is configured."]
        </div>
    }

    <p class="text-muted">
        @L["Everything that happens is recorded here whatever your email setting, so turning email off costs you nothing."]
    </p>

    @if (Model.Notifications.Count == 0)
    {
        <p class="text-muted fst-italic">@L["Nothing yet."]</p>
    }
    else
    {
        <form method="post" asp-action="MarkAllRead" class="mb-2">
            <button class="btn btn-sm btn-outline-secondary">@L["Mark everything as read"]</button>
        </form>

        <div class="list-group">
        @foreach (var notification in Model.Notifications)
        {
            <a href="@notification.Link"
               class="list-group-item list-group-item-action @(notification.IsRead ? "" : "list-group-item-light")">
                @if (!notification.IsRead)
                {
                    <span class="badge bg-primary">@L["new"]</span>
                }
                @notification.Summary
                <small class="d-block text-muted">
                    @notification.CreatedAtUtc.ToString("d MMM yyyy HH:mm") UTC
                </small>
            </a>
        }
        </div>
    }
</div>
