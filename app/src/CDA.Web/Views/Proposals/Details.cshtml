@model CDA.Web.Models.ProposalDetailsViewModel
@using CDA.Domain.Proposals
@using CDA.Domain.References
@{
    ViewData["Title"] = L["Proposal"];
    var proposal = Model.Proposal;
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-action="Index" asp-route-topicId="@Model.Topic.Id" class="text-decoration-none">
        &larr; @L.Format("Proposals for %topic%", ("topic", Model.Topic.Subject))
    </a>
</p>

<div class="col-lg-9">
    <h1 class="h3">@proposal.Text</h1>

    <p class="text-muted">
        <a asp-controller="Profile" asp-action="Details" asp-route-id="@proposal.AuthorId"
           class="text-decoration-none">@proposal.AuthorDisplayName</a>
        &middot; @proposal.CreatedAtUtc.ToString("d MMM yyyy HH:mm") UTC
        @if (proposal.EditedAtUtc is not null)
        {
            <span>&middot; @L["edited"]</span>
        }
    </p>

    @if (!proposal.IsLocked)
    {
        <div class="alert alert-warning">
            <strong>@L["Still open for improvement."]</strong>
            @L.Format("The author can change the wording until %date% UTC, so voting is not open yet — a vote cast now would attach to wording that changes underneath it. Comments are welcome, and are how the author finds out what to improve.", ("date", proposal.EditableUntilUtc.ToString("d MMM yyyy HH:mm")))
        </div>
    }

    @if (proposal.CanEdit)
    {
        <form method="post" asp-action="Edit" asp-route-topicId="@Model.Topic.Id" asp-route-id="@proposal.Id"
              class="border rounded p-3 mb-3">
            <label class="form-label">@L["Improve the wording"]</label>
            <textarea name="text" class="form-control mb-2" rows="2" required
                      maxlength="@Proposal.TextMaxLength">@proposal.Text</textarea>
            <button class="btn btn-sm btn-primary">@L["Save"]</button>
        </form>

        <form method="post" asp-action="Lock" asp-route-topicId="@Model.Topic.Id" asp-route-id="@proposal.Id"
              class="mb-4">
            <button class="btn btn-sm btn-outline-dark">@L["Finish editing and open voting"]</button>
            <span class="form-text ms-2">
                @L["This cannot be undone — once people have voted, the wording is what they voted on."]
            </span>
        </form>
    }

    <div class="card my-4">
        <div class="card-body">
            <h2 class="h6 card-title">@L["Do you support this proposal?"]</h2>

            @if (!proposal.IsLocked)
            {
                <p class="text-muted mb-0">@L["Voting opens when the author finishes editing."]</p>
            }
            else
            {
                @if (proposal.ScoreSum is { } score)
                {
                    <p class="mb-2">
                        <span class="h4">@(score > 0 ? "+" : "")@score</span>
                        <small class="text-muted">@L.Format(proposal.VoteCount == 1 ? "from %count% vote" : "from %count% votes", ("count", proposal.VoteCount))</small>
                    </p>
                }
                else
                {
                    <p class="text-muted mb-2">@L["This topic withholds its tallies until it closes."]</p>
                }

                @if (proposal.CanVote)
                {
                    <form method="post" asp-action="Vote" asp-route-topicId="@Model.Topic.Id"
                          asp-route-id="@proposal.Id" class="d-inline">
                        <button name="value" value="1" class="btn btn-sm @(proposal.MyVote == 1 ? "btn-success" : "btn-outline-success")">@L["Support"]</button>
                        <button name="value" value="0" class="btn btn-sm @(proposal.MyVote == 0 ? "btn-secondary" : "btn-outline-secondary")">@L["Neutral"]</button>
                        <button name="value" value="-1" class="btn btn-sm @(proposal.MyVote == -1 ? "btn-danger" : "btn-outline-danger")">@L["Oppose"]</button>
                    </form>
                    @if (proposal.MyVote is not null)
                    {
                        <form method="post" asp-action="WithdrawVote" asp-route-topicId="@Model.Topic.Id"
                              asp-route-id="@proposal.Id" class="d-inline">
                            <button class="btn btn-sm btn-link text-muted">@L["Withdraw my vote"]</button>
                        </form>
                    }
                }
                else if (User.Identity?.IsAuthenticated != true)
                {
                    <p class="mb-0">@Html.Raw(L.Format("%link% to vote.", ("link", $"<a href=\"{Url.Action("Login", "Account")}\">{L["Sign in"]}</a>")))</p>
                }
            }
        </div>
    </div>

    @* --- Duplicates: reported by people, never decided by the platform --- *@
    <h2 class="h5">@L["Similar proposals"]</h2>

    @if (Model.Similarities.Count == 0)
    {
        <p class="text-muted fst-italic">@L["Nobody has reported this as a duplicate of anything."]</p>
    }

    @foreach (var similar in Model.Similarities)
    {
        <div class="border rounded p-3 mb-2">
            <div>
                <a asp-action="Details" asp-route-topicId="@Model.Topic.Id" asp-route-id="@similar.OtherProposalId">
                    @similar.OtherProposalText
                </a>
                @if (similar.IsActive)
                {
                    <span class="badge bg-info text-dark" title="@L["Enough agreement to fold at this topic's default threshold."]">@L["active"]</span>
                }
                <div class="small text-muted">
                    @L["reported by"]
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@similar.ReportedByUserId"
                       class="text-muted">@similar.ReportedByDisplayName</a>
                    &middot; @(similar.ScoreSum > 0 ? "+" : "")@similar.ScoreSum
                    @L.Format(similar.VoteCount == 1 ? "from %count% vote" : "from %count% votes", ("count", similar.VoteCount))
                    @if (similar.BetterWrittenProposalId == Model.Proposal.Id)
                    {
                        <span>&middot; @L["judged the better written of the two"]</span>
                    }
                </div>
                @if (similar.Justification is not null)
                {
                    <p class="small mb-0 mt-1" style="white-space: pre-wrap">@similar.Justification</p>
                }
            </div>

            @if (Model.CanCite)
            {
                <div class="mt-2">
                    <span class="small me-2">@L["Are these the same?"]</span>
                    <form method="post" asp-action="VoteOnSimilarity" asp-route-topicId="@Model.Topic.Id"
                          asp-route-id="@Model.Proposal.Id" asp-route-similarityId="@similar.Id" class="d-inline">
                        <button name="value" value="1" class="btn btn-sm @(similar.MyVote == 1 ? "btn-success" : "btn-outline-success")">@L["Yes"]</button>
                        <button name="value" value="0" class="btn btn-sm @(similar.MyVote == 0 ? "btn-secondary" : "btn-outline-secondary")">@L["Unsure"]</button>
                        <button name="value" value="-1" class="btn btn-sm @(similar.MyVote == -1 ? "btn-danger" : "btn-outline-danger")">@L["No"]</button>
                    </form>
                </div>

                @* The split this whole mechanism exists to prevent: agreeing two proposals say
                   the same thing while backing them differently divides their support. *@
                @if (similar.MyVote == 1 && similar.MyVoteOnThis is { } here
                     && similar.MyVoteOnOther is { } there && here != there)
                {
                    <div class="alert alert-warning mt-2 mb-0 small">
                        @L.Format("You agree these two say the same thing, but you voted %here% on this one and %there% on the other. That splits the support for a single idea across two entries. Consider voting the same on both.", ("here", here), ("there", there))
                    </div>
                }
            }
        </div>
    }

    @if (Model.CanCite)
    {
        <form method="post" asp-action="ReportSimilar" asp-route-topicId="@Model.Topic.Id"
              asp-route-id="@Model.Proposal.Id" class="border-top pt-3 mb-4">
            <label class="form-label mb-0">@L["Report a duplicate"]</label>
            <div class="form-text mb-2">
                @L["Paste the id of the other proposal from its address bar. Nothing is merged — you are recording a claim that others can agree or disagree with."]
            </div>
            <input name="otherProposalId" class="form-control mb-2" required
                   placeholder="@L["Other proposal id"]" />
            <input name="justification" class="form-control mb-2" maxlength="1000"
                   placeholder="@L["Why do you think they say the same thing? (optional)"]" />
            <select name="betterWrittenProposalId" class="form-select mb-2">
                <option value="">@L["No preference on wording"]</option>
                <option value="@Model.Proposal.Id">@L["This one is better written"]</option>
            </select>
            <button class="btn btn-outline-primary btn-sm">@L["Report as similar"]</button>
        </form>
    }

    @* --- Sources: what this proposal is argued from --- *@
    <h2 class="h5">@L["Sources"]</h2>
    <p class="text-muted">
        @L["Each source is judged on two separate questions, because they come apart: something can be entirely accurate and beside the point, or highly relevant and unreliable."]
    </p>

    @if (Model.References.Count == 0)
    {
        <p class="text-muted fst-italic">@L["Nothing cited yet."]</p>
    }

    @foreach (var reference in Model.References)
    {
        <div class="border rounded p-3 mb-2">
            <div>
                @* User-supplied and unverified, so no ranking credit and no referrer. *@
                <a href="@reference.Url" rel="nofollow noopener noreferrer" target="_blank">
                    @reference.Description
                </a>
                <div class="small text-muted text-break">@reference.Url</div>
                <div class="small text-muted">
                    @L["cited by"]
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@reference.CitedByUserId"
                       class="text-muted">@reference.CitedByDisplayName</a>
                    @if (reference.UsedByProposalCount > 1)
                    {
                        <span>&middot; @L.Format(reference.UsedByProposalCount == 2 ? "also supports %count% other proposal" : "also supports %count% other proposals", ("count", reference.UsedByProposalCount - 1))</span>
                    }
                </div>
            </div>

            <div class="row mt-2 g-3">
                @foreach (var aspect in new[] { ReferenceAspect.Accuracy, ReferenceAspect.Importance })
                {
                    var score = aspect == ReferenceAspect.Accuracy ? reference.AccuracyScore : reference.ImportanceScore;
                    var votes = aspect == ReferenceAspect.Accuracy ? reference.AccuracyVotes : reference.ImportanceVotes;
                    var mine = aspect == ReferenceAspect.Accuracy ? reference.MyAccuracyVote : reference.MyImportanceVote;
                    var question = aspect == ReferenceAspect.Accuracy
                        ? L["Is it accurate?"]
                        : L["Does it matter here?"];

                    <div class="col-sm-6">
                        <div class="small fw-semibold">@question</div>
                        <div class="small text-muted mb-1">
                            @(score > 0 ? "+" : "")@score @L.Format(votes == 1 ? "from %count% vote" : "from %count% votes", ("count", votes))
                        </div>
                        @if (Model.CanCite)
                        {
                            <form method="post" asp-action="VoteOnReference" asp-route-topicId="@Model.Topic.Id"
                                  asp-route-id="@Model.Proposal.Id" asp-route-referenceId="@reference.Id"
                                  class="d-inline">
                                <input type="hidden" name="aspect" value="@aspect" />
                                <button name="value" value="1" class="btn btn-sm @(mine == 1 ? "btn-success" : "btn-outline-success")">&plus;</button>
                                <button name="value" value="0" class="btn btn-sm @(mine == 0 ? "btn-secondary" : "btn-outline-secondary")">0</button>
                                <button name="value" value="-1" class="btn btn-sm @(mine == -1 ? "btn-danger" : "btn-outline-danger")">&minus;</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.CanCite)
    {
        <form method="post" asp-action="AddReference" asp-route-topicId="@Model.Topic.Id"
              asp-route-id="@Model.Proposal.Id" class="border-top pt-3 mb-4">
            <div class="mb-2">
                <label class="form-label mb-0">@L["Cite a source"]</label>
                <input name="url" class="form-control" placeholder="https://" required />
            </div>
            <div class="mb-2">
                <input name="description" class="form-control" required maxlength="500"
                       placeholder="@L["What is it? e.g. 2024 city council traffic study, pages 12–18"]" />
            </div>
            <button class="btn btn-outline-primary btn-sm">@L["Add source"]</button>
            <span class="form-text ms-2">
                @L["If this source is already cited elsewhere in the topic, it will be linked rather than duplicated — so its rating stays in one place."]
            </span>
        </form>
    }

    @* --- Attachments: for what has no link of its own --- *@
    <section id="attachments">
        <h2 class="h5">@L["Attached files"]</h2>

        @if (Model.Attachments.Count == 0)
        {
            <p class="text-muted fst-italic">@L["Nothing attached."]</p>
        }

        <ul class="list-unstyled">
        @foreach (var attachment in Model.Attachments)
        {
            <li class="mb-1">
                <a asp-action="Download" asp-route-topicId="@Model.Topic.Id" asp-route-id="@Model.Proposal.Id"
                   asp-route-attachmentId="@attachment.Id">@attachment.FileName</a>
                <small class="text-muted">
                    @CDA.Web.Models.FileSize.Describe(attachment.SizeBytes)
                    &middot; @attachment.UploadedByDisplayName
                </small>
            </li>
        }
        </ul>

        @if (Model.CanCite)
        {
            <form method="post" asp-action="AddAttachment" asp-route-topicId="@Model.Topic.Id"
                  asp-route-id="@Model.Proposal.Id" enctype="multipart/form-data" class="mb-4">
                <div class="row g-2">
                    <div class="col">
                        <input type="file" name="file" class="form-control" required />
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-primary btn-sm">@L["Attach"]</button>
                    </div>
                </div>
                <div class="form-text">
                    @L.Format("Up to %count% MB. Documents, spreadsheets, images, PDFs and plain text. If it is already on the web, cite it as a source instead — a link keeps its context.", ("count", CDA.Domain.Attachments.Attachment.MaxSizeBytes / (1024 * 1024)))
                </div>
            </form>
        }
    </section>

    @* The conversation about the proposal, kept structurally apart from the proposal itself. *@
    <h2 class="h5">@L["Comments"]</h2>

    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted fst-italic">@L["No comments yet."]</p>
    }

    @foreach (var comment in Model.Comments)
    {
        <div class="border-bottom py-2">
            <div class="d-flex justify-content-between">
                <strong>
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@comment.AuthorId"
                       class="text-decoration-none">@comment.AuthorDisplayName</a>
                </strong>
                <small class="text-muted">@comment.CreatedAtUtc.ToString("d MMM yyyy HH:mm") UTC</small>
            </div>
            @if (comment.IsDeleted)
            {
                <p class="text-muted fst-italic mb-0">@L["This comment was withdrawn."]</p>
            }
            else
            {
                <p class="mb-0" style="white-space: pre-wrap">@comment.Body</p>
            }
        </div>
    }

    @if (proposal.CanComment)
    {
        <form method="post" asp-action="PostComment" asp-route-topicId="@Model.Topic.Id"
              asp-route-id="@proposal.Id" class="mt-3">
            <textarea name="body" class="form-control" rows="3" maxlength="8000" required
                      placeholder="@(proposal.IsLocked ? L["Add a comment…"] : L["Suggest an improvement…"])"></textarea>
            <button class="btn btn-primary mt-2">@L["Post comment"]</button>
        </form>
    }
</div>
