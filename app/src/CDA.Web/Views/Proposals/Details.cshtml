@model CDA.Web.Models.ProposalDetailsViewModel
@using CDA.Domain.Proposals
@using CDA.Domain.References
@{
    ViewData["Title"] = "Proposal";
    var proposal = Model.Proposal;
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-action="Index" asp-route-topicId="@Model.Topic.Id" class="text-decoration-none">
        &larr; Proposals for @Model.Topic.Subject
    </a>
</p>

<div class="col-lg-9">
    <h1 class="h3">@proposal.Text</h1>

    <p class="text-muted">
        <a asp-controller="Profile" asp-action="Details" asp-route-id="@proposal.AuthorId"
           class="text-decoration-none">@proposal.AuthorDisplayName</a>
        &middot; @proposal.CreatedAtUtc.ToString("d MMM yyyy HH:mm") UTC
        @if (proposal.EditedAtUtc is not null)
        {
            <span>&middot; edited</span>
        }
    </p>

    @if (!proposal.IsLocked)
    {
        <div class="alert alert-warning">
            <strong>Still open for improvement.</strong>
            The author can change the wording until
            @proposal.EditableUntilUtc.ToString("d MMM yyyy HH:mm") UTC, so voting is not open
            yet — a vote cast now would attach to wording that changes underneath it. Comments
            are welcome, and are how the author finds out what to improve.
        </div>
    }

    @if (proposal.CanEdit)
    {
        <form method="post" asp-action="Edit" asp-route-topicId="@Model.Topic.Id" asp-route-id="@proposal.Id"
              class="border rounded p-3 mb-3">
            <label class="form-label">Improve the wording</label>
            <textarea name="text" class="form-control mb-2" rows="2" required
                      maxlength="@Proposal.TextMaxLength">@proposal.Text</textarea>
            <button class="btn btn-sm btn-primary">Save</button>
        </form>

        <form method="post" asp-action="Lock" asp-route-topicId="@Model.Topic.Id" asp-route-id="@proposal.Id"
              class="mb-4">
            <button class="btn btn-sm btn-outline-dark">Finish editing and open voting</button>
            <span class="form-text ms-2">
                This cannot be undone — once people have voted, the wording is what they voted on.
            </span>
        </form>
    }

    <div class="card my-4">
        <div class="card-body">
            <h2 class="h6 card-title">Do you support this proposal?</h2>

            @if (!proposal.IsLocked)
            {
                <p class="text-muted mb-0">Voting opens when the author finishes editing.</p>
            }
            else
            {
                @if (proposal.ScoreSum is { } score)
                {
                    <p class="mb-2">
                        <span class="h4">@(score > 0 ? "+" : "")@score</span>
                        <small class="text-muted">from @proposal.VoteCount vote@(proposal.VoteCount == 1 ? "" : "s")</small>
                    </p>
                }
                else
                {
                    <p class="text-muted mb-2">This topic withholds its tallies until it closes.</p>
                }

                @if (proposal.CanVote)
                {
                    <form method="post" asp-action="Vote" asp-route-topicId="@Model.Topic.Id"
                          asp-route-id="@proposal.Id" class="d-inline">
                        <button name="value" value="1" class="btn btn-sm @(proposal.MyVote == 1 ? "btn-success" : "btn-outline-success")">Support</button>
                        <button name="value" value="0" class="btn btn-sm @(proposal.MyVote == 0 ? "btn-secondary" : "btn-outline-secondary")">Neutral</button>
                        <button name="value" value="-1" class="btn btn-sm @(proposal.MyVote == -1 ? "btn-danger" : "btn-outline-danger")">Oppose</button>
                    </form>
                    @if (proposal.MyVote is not null)
                    {
                        <form method="post" asp-action="WithdrawVote" asp-route-topicId="@Model.Topic.Id"
                              asp-route-id="@proposal.Id" class="d-inline">
                            <button class="btn btn-sm btn-link text-muted">Withdraw my vote</button>
                        </form>
                    }
                }
                else if (User.Identity?.IsAuthenticated != true)
                {
                    <p class="mb-0"><a asp-controller="Account" asp-action="Login">Sign in</a> to vote.</p>
                }
            }
        </div>
    </div>

    @* --- Sources: what this proposal is argued from --- *@
    <h2 class="h5">Sources</h2>
    <p class="text-muted">
        Each source is judged on two separate questions, because they come apart: something can
        be entirely accurate and beside the point, or highly relevant and unreliable.
    </p>

    @if (Model.References.Count == 0)
    {
        <p class="text-muted fst-italic">Nothing cited yet.</p>
    }

    @foreach (var reference in Model.References)
    {
        <div class="border rounded p-3 mb-2">
            <div>
                @* User-supplied and unverified, so no ranking credit and no referrer. *@
                <a href="@reference.Url" rel="nofollow noopener noreferrer" target="_blank">
                    @reference.Description
                </a>
                <div class="small text-muted text-break">@reference.Url</div>
                <div class="small text-muted">
                    cited by
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@reference.CitedByUserId"
                       class="text-muted">@reference.CitedByDisplayName</a>
                    @if (reference.UsedByProposalCount > 1)
                    {
                        <span>&middot; also supports @(reference.UsedByProposalCount - 1) other proposal@(reference.UsedByProposalCount == 2 ? "" : "s")</span>
                    }
                </div>
            </div>

            <div class="row mt-2 g-3">
                @foreach (var aspect in new[] { ReferenceAspect.Accuracy, ReferenceAspect.Importance })
                {
                    var score = aspect == ReferenceAspect.Accuracy ? reference.AccuracyScore : reference.ImportanceScore;
                    var votes = aspect == ReferenceAspect.Accuracy ? reference.AccuracyVotes : reference.ImportanceVotes;
                    var mine = aspect == ReferenceAspect.Accuracy ? reference.MyAccuracyVote : reference.MyImportanceVote;
                    var question = aspect == ReferenceAspect.Accuracy
                        ? "Is it accurate?"
                        : "Does it matter here?";

                    <div class="col-sm-6">
                        <div class="small fw-semibold">@question</div>
                        <div class="small text-muted mb-1">
                            @(score > 0 ? "+" : "")@score from @votes vote@(votes == 1 ? "" : "s")
                        </div>
                        @if (Model.CanCite)
                        {
                            <form method="post" asp-action="VoteOnReference" asp-route-topicId="@Model.Topic.Id"
                                  asp-route-id="@Model.Proposal.Id" asp-route-referenceId="@reference.Id"
                                  class="d-inline">
                                <input type="hidden" name="aspect" value="@aspect" />
                                <button name="value" value="1" class="btn btn-sm @(mine == 1 ? "btn-success" : "btn-outline-success")">&plus;</button>
                                <button name="value" value="0" class="btn btn-sm @(mine == 0 ? "btn-secondary" : "btn-outline-secondary")">0</button>
                                <button name="value" value="-1" class="btn btn-sm @(mine == -1 ? "btn-danger" : "btn-outline-danger")">&minus;</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.CanCite)
    {
        <form method="post" asp-action="AddReference" asp-route-topicId="@Model.Topic.Id"
              asp-route-id="@Model.Proposal.Id" class="border-top pt-3 mb-4">
            <div class="mb-2">
                <label class="form-label mb-0">Cite a source</label>
                <input name="url" class="form-control" placeholder="https://" required />
            </div>
            <div class="mb-2">
                <input name="description" class="form-control" required maxlength="500"
                       placeholder="What is it? e.g. 2024 city council traffic study, pages 12–18" />
            </div>
            <button class="btn btn-outline-primary btn-sm">Add source</button>
            <span class="form-text ms-2">
                If this source is already cited elsewhere in the topic, it will be linked rather
                than duplicated — so its rating stays in one place.
            </span>
        </form>
    }

    @* The conversation about the proposal, kept structurally apart from the proposal itself. *@
    <h2 class="h5">Comments</h2>

    @if (Model.Comments.Count == 0)
    {
        <p class="text-muted fst-italic">No comments yet.</p>
    }

    @foreach (var comment in Model.Comments)
    {
        <div class="border-bottom py-2">
            <div class="d-flex justify-content-between">
                <strong>
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@comment.AuthorId"
                       class="text-decoration-none">@comment.AuthorDisplayName</a>
                </strong>
                <small class="text-muted">@comment.CreatedAtUtc.ToString("d MMM yyyy HH:mm") UTC</small>
            </div>
            @if (comment.IsDeleted)
            {
                <p class="text-muted fst-italic mb-0">This comment was withdrawn.</p>
            }
            else
            {
                <p class="mb-0" style="white-space: pre-wrap">@comment.Body</p>
            }
        </div>
    }

    @if (proposal.CanComment)
    {
        <form method="post" asp-action="PostComment" asp-route-topicId="@Model.Topic.Id"
              asp-route-id="@proposal.Id" class="mt-3">
            <textarea name="body" class="form-control" rows="3" maxlength="8000" required
                      placeholder="@(proposal.IsLocked ? "Add a comment…" : "Suggest an improvement…")"></textarea>
            <button class="btn btn-primary mt-2">Post comment</button>
        </form>
    }
</div>
