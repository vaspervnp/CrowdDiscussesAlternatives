@model CDA.Web.Models.ProposalListViewModel
@using CDA.Domain.Proposals
@using CDA.Infrastructure.Proposals
@{
    ViewData["Title"] = $"Proposals — {Model.Topic.Subject}";
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-warning">@error</div>
}

<p class="mb-1">
    <a asp-controller="Topics" asp-action="Details" asp-route-id="@Model.Topic.Id"
       class="text-decoration-none">&larr; @Model.Topic.Subject</a>
</p>
<h1>Proposals</h1>

<p class="text-muted col-lg-9">
    The pool of building blocks for this topic. Each one is roughly a sentence, so that the
    parts people agree on can be reused in an alternative that fixes the parts they do not.
</p>

<div class="d-flex justify-content-between align-items-center mb-3">
    <ul class="nav nav-pills">
        <li class="nav-item">
            <a class="nav-link @(Model.Sort == ProposalSort.Score ? "active" : "")"
               asp-action="Index" asp-route-topicId="@Model.Topic.Id"
               asp-route-sort="@ProposalSort.Score" asp-route-author="@Model.AuthorFilter">Most supported</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.Sort == ProposalSort.Newest ? "active" : "")"
               asp-action="Index" asp-route-topicId="@Model.Topic.Id"
               asp-route-sort="@ProposalSort.Newest" asp-route-author="@Model.AuthorFilter">Newest</a>
        </li>
        <li class="nav-item">
            @* How someone who has been away catches up with an argument in progress. *@
            <a class="nav-link @(Model.Sort == ProposalSort.LastCommented ? "active" : "")"
               asp-action="Index" asp-route-topicId="@Model.Topic.Id"
               asp-route-sort="@ProposalSort.LastCommented" asp-route-author="@Model.AuthorFilter">Recently discussed</a>
        </li>
    </ul>
</div>

@if (Model.AuthorFilter is not null)
{
    <p>
        Showing only proposals by <strong>@Model.AuthorFilterName</strong>.
        <a asp-action="Index" asp-route-topicId="@Model.Topic.Id" asp-route-sort="@Model.Sort">Show everyone's</a>
    </p>
}

@if (Model.Proposals.Count == 0)
{
    <p class="text-muted fst-italic">No proposals yet.</p>
}

<div class="list-group mb-3">
@foreach (var proposal in Model.Proposals)
{
    <div class="list-group-item">
        <div class="d-flex justify-content-between">
            <div class="pe-3">
                <a asp-action="Details" asp-route-topicId="@Model.Topic.Id" asp-route-id="@proposal.Id"
                   class="text-decoration-none d-block">@proposal.Text</a>
                <small class="text-muted">
                    <a asp-action="Index" asp-route-topicId="@Model.Topic.Id" asp-route-sort="@Model.Sort"
                       asp-route-author="@proposal.AuthorId" class="text-muted">@proposal.AuthorDisplayName</a>
                    &middot; @proposal.CommentCount comment@(proposal.CommentCount == 1 ? "" : "s")
                    @if (!proposal.IsLocked)
                    {
                        <span class="badge bg-warning text-dark"
                              title="Still open for improvement, so it cannot be voted on yet.">editable</span>
                    }
                </small>
            </div>
            <div class="text-end text-nowrap">
                @if (!proposal.IsLocked)
                {
                    <small class="text-muted">voting not open</small>
                }
                else if (proposal.ScoreSum is { } score)
                {
                    <span class="h5">@(score > 0 ? "+" : "")@score</span><br />
                    <small class="text-muted">@proposal.VoteCount vote@(proposal.VoteCount == 1 ? "" : "s")</small>
                }
                else
                {
                    <small class="text-muted">counts hidden</small>
                }
            </div>
        </div>
    </div>
}
</div>

@if (Model.NextCursor is not null)
{
    <a class="btn btn-outline-secondary mb-3"
       asp-action="Index" asp-route-topicId="@Model.Topic.Id" asp-route-sort="@Model.Sort"
       asp-route-author="@Model.AuthorFilter" asp-route-cursor="@Model.NextCursor">Show more</a>
}

@if (Model.CanAdd)
{
    <div class="border-top pt-3 col-lg-9">
        <h2 class="h5">Add a proposal</h2>
        <form method="post" asp-action="Create" asp-route-topicId="@Model.Topic.Id">
            <div class="mb-2">
                <textarea name="text" class="form-control" rows="2" required
                          maxlength="@Proposal.TextMaxLength"
                          placeholder="One sentence — a single building block, not a whole solution."></textarea>
                <div class="form-text">
                    Up to @Proposal.TextMaxLength characters. If your idea needs more, it is more
                    than one proposal — split it, so people can accept the parts they agree with.
                </div>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-0" for="editableForDays">Stay editable for</label>
                    <select name="editableForDays" id="editableForDays" class="form-select">
                        <option value="0">3 days (default)</option>
                        <option value="1">1 day</option>
                        <option value="7">7 days</option>
                        <option value="14">14 days</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary">Add proposal</button>
                </div>
            </div>
            <div class="form-text">
                While it stays editable you can improve it in response to comments, and nobody
                can vote on it yet. You can end that window early at any time.
            </div>
        </form>
    </div>
}
else if (Model.Topic.Phase != CDA.Domain.Topics.TopicPhase.Proposing)
{
    <p class="text-muted">
        This topic is still agreeing its requirements. Proposals open once the facilitator has
        published them.
    </p>
}
