@using CDA.Infrastructure.Identity
@using CDA.Infrastructure.Messaging
@using CDA.Infrastructure.Notifications
@using CDA.Web.Security
@using Microsoft.AspNetCore.Identity
@inject SignInManager<CdaUser> SignInManager
@inject UserManager<CdaUser> UserManager
@inject NotificationService Notifications
@inject MessageService Messages

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    @*
        Two indexed counts per page render. Worth it: without a number here you would have to
        open the page to discover there was anything on it, which is the polling this phase
        exists to remove.
    *@
    var me = User.GetUserId()!.Value;
    var unreadNotifications = await Notifications.UnreadCountAsync(me);
    var unreadMessages = await Messages.UnreadCountAsync(me);

    <li class="nav-item">
        <a class="nav-link" asp-controller="Notifications" asp-action="Index">
            @L["Notifications"]
            @if (unreadNotifications > 0)
            {
                <span class="badge bg-primary">@unreadNotifications</span>
            }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Messages" asp-action="Index">
            @L["Messages"]
            @if (unreadMessages > 0)
            {
                <span class="badge bg-primary">@unreadMessages</span>
            }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Profile" asp-action="Edit">@L["My profile"]</a>
    </li>
    @if (User.IsInRole(CdaRole.Administrator))
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Localization" asp-action="Index">@L["Translations"]</a>
        </li>
    }
    <li class="nav-item">
        @* A POST, so that a link on another site cannot sign the user out. *@
        <form method="post" asp-controller="Account" asp-action="Logout">
            <button type="submit" class="nav-link btn btn-link">@L["Sign out"]</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Register">@L["Register"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Login">@L["Sign in"]</a>
    </li>
}
</ul>
