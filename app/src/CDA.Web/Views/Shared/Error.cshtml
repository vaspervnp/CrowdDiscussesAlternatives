@model ErrorViewModel
@{
    ViewData["Title"] = L["Error"];
}

<h1 class="text-danger">@L["Error"]</h1>
<h2 class="text-danger">@L["Something went wrong while handling your request."]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@L["Request ID:"]</strong> <code>@Model.RequestId</code>
    </p>
}

<p>@L["If it keeps happening, quoting the request ID above will help whoever looks into it."]</p>
